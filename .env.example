# Sao chép file này thành ".env" rồi điền giá trị thật.

# API Key của Google Custom Search API
# Lấy tại: https://console.cloud.google.com/apis/credentials
GOOGLE_API_KEY=

# Search Engine ID (cx) của Programmable Search Engine
# Lấy tại: https://programmablesearchengine.google.com/  -> tạo engine -> "Search engine ID"
GOOGLE_CX=

# Cổng chạy server (tuỳ chọn)
PORT=3000
